# -----------------------------------------------------------------------------
# Ghostty Configuration
#
# Config refresh: Shift + Cmd + ,
# -----------------------------------------------------------------------------

# --- Theme & Appearance ---
theme = iTerm2 Dark Background
font-family = UDEV Gothic
font-size = 23
font-thicken = true

# --- Terminal & Shell ---
shell-integration = zsh
shell-integration-features = no-cursor
copy-on-select = clipboard

# --- Window & Display ---
cursor-style = block
cursor-style-blink = false
macos-titlebar-style = tabs
window-padding-x = 2
window-padding-y = 2
window-padding-balance = true
window-save-state = always
scrollback-limit = 20000
confirm-close-surface = false
quit-after-last-window-closed = true
unfocused-split-opacity = 0.825
quick-terminal-position = bottom
quick-terminal-animation-duration = 0.2

# --- Keybindings ---
macos-option-as-alt = true
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+left_bracket=goto_split:previous
keybind = cmd+right_bracket=goto_split:next
keybind = cmd+w=close_surface
keybind = global:opt+space=toggle_quick_terminal

# --- Hotkey Window (Quick Terminal) ---
keybind = global:opt+space=toggle_quick_terminal
quick-terminal-position = bottom
quick-terminal-animation-duration = 0.2
quick-terminal-size = 30%
quick-terminal-autohide = true

# --- Additional Settings ---
config-file = "?~/dotfiles/.ghostty_local"
